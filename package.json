{
  "name": "@randajan/browser-files",
  "version": "1.0.2",
  "description": "Lightweight browser library for reading and saving files with customizable serialization.",
  "repository": "randajan/browser-files",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "exports": {
