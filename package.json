  ],
  "keywords": [
    "browser",
    "file",
    "files",
    "file-io",
    "file-upload",
    "file-download",
    "file-reader",
    "file-writer",
    "blob",
    "frontend",
    "client-side",
    "json",
    "text",
    "serialization",
    "deserialization",
    "utility",
    "utils"
  ],
  "homepage": "https://github.com/randajan/browser-files",
  "bugs": {
    "url": "https://github.com/randajan/browser-files/issues"
  },
  "author": {
    "name": "Jan Randa",
